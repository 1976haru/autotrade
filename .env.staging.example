# 체크리스트 #67: Staging 환경 변수 example.
#
# 사용법:
#   cp .env.staging.example .env.staging
#   # .env.staging만 편집 — git 추적 X (.gitignore에 등록됨)
#
# 절대 원칙 (CLAUDE.md):
#   1. 실 API key / Secret / 계좌번호를 본 *example*에 절대 입력하지 않는다.
#      운영자가 로컬 .env.staging에서만 채운다.
#   2. ENABLE_LIVE_TRADING / ENABLE_AI_EXECUTION / FUTURES_LIVE는 staging
#      에서 *true로 설정 금지*. docker-compose.staging.yml에 "false"로
#      하드코딩되어 있고, 본 env가 override되어도 false 유지 권장.
#   3. STAGING_KIS_* / STAGING_ANTHROPIC_API_KEY / STAGING_TELEGRAM_BOT_TOKEN
#      은 빈 값 default 유지 권장. 채우면 *KIS_IS_PAPER=true 조합에서만* 의미.

# ---- Postgres (staging — 운영 DB와 별개) ----
STAGING_PG_DB=autotrader_staging
STAGING_PG_USER=autotrader
# 본 placeholder는 *실제 비밀번호가 아님*. 운영자가 .env.staging에서 강한 값으로 변경.
STAGING_PG_PASSWORD=staging_only_placeholder_change_me

# ---- Backend mode ----
# SIMULATION | PAPER. LIVE_*는 staging 금지.
STAGING_DEFAULT_MODE=SIMULATION

# ---- Frontend 빌드 시 backend URL ----
# Docker compose는 backend를 host의 18000 포트로 노출. 외부 staging 서버 배포
# 시에는 그 머신의 IP / 도메인으로 변경.
STAGING_FRONTEND_BACKEND_URL=http://localhost:18000

# ---- Optional: KIS Paper / Anthropic / Telegram ----
# 빈 값 유지 권장. 채우려면:
#   - KIS_IS_PAPER=true 조합에서만 (docker-compose.staging.yml에 강제 설정됨)
#   - Anthropic 키는 사용 시 *비용 발생* — staging에서 의도적으로 끄는 게 안전
#   - Telegram은 NOTIFICATIONS_ENABLED=false default이므로 채워도 발송 0건
STAGING_KIS_APP_KEY=
STAGING_KIS_APP_SECRET=
STAGING_KIS_ACCOUNT_NO=
STAGING_ANTHROPIC_API_KEY=
STAGING_TELEGRAM_BOT_TOKEN=
STAGING_TELEGRAM_CHAT_ID=
