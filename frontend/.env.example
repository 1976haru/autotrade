VITE_BACKEND_URL=http://127.0.0.1:8000

# 50: Futures 탭은 *UI 노출* 전용 feature flag로 navigation에서 숨겨진다.
# 기본값은 false — 운영자가 명시적으로 true로 설정해야만 PC TopNav에 노출.
# 본 flag는 backend의 ENABLE_FUTURES_LIVE_TRADING과 *무관*. 실제 선물 주문이
# broker로 가는지 여부에는 어떤 영향도 주지 않는다 (broker 호출은 backend의
# FuturesRiskManager.evaluate_order 항상 REJECTED + adapter 미존재로 0건).
#
# 모바일 BottomNav에는 flag=true여도 Futures가 직접 노출되지 *않는다*
# (사용자 혼동 방지 정책). 자세한 내용: docs/futures_ui.md (#50).
VITE_ENABLE_FUTURES_TAB=false
