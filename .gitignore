# ============================================================
# Agent Trader v1 — .gitignore
#
# 단일 진실:
#   - Secret 보호 (`.env`, `*.key`, `*.pem`) — 절대 commit 금지
#   - 운영 데이터 (`data/`, `logs/`, `backups/`, `*.sqlite`) — git 추적 0건
#   - build artifact (`dist/`, `node_modules/`, `__pycache__/`) — 추적 X
#
# 본 파일 변경 시 `tests/test_repository_hygiene.py` 의 정적 검사가 깨지지
# 않는지 확인 (.env / .env.example allowlist / backups 등 핵심 패턴 유지).
# ============================================================


# ---------- env / secrets ----------
.env
.env.*
!.env.example
!.env.staging.example
*.pem
*.key
backend/.env
frontend/.env
*.local


# ---------- Python ----------
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
# project-local venvs (#88 — explicit so backend/.venv-310/ stops showing as
# untracked in `git status`).
.venv-310/
backend/.venv-310/


# ---------- Node / build ----------
node_modules/
dist/
build/
.vite/
.cache/
coverage/


# ---------- IDE / OS ----------
.DS_Store
.vscode/
.idea/
.claude/


# ---------- logs / data ----------
*.log
logs/
data/
*.sqlite
*.db


# ---------- local reports — daily_report_agent 산출물 ----------
# .gitkeep placeholder만 추적되도록.
reports/*
!reports/.gitkeep


# ---------- DB backups (#69) ----------
# scripts/backup_db.sh 산출물. 운영 데이터(주문 / 감사 로그 / 가상 거래 등)가
# 포함될 수 있으므로 git 추적 0건. backups/ 디렉터리는 .gitkeep placeholder만.
backups/*
!backups/.gitkeep
*.sql.gz
*.db.backup
*.sqlite.bak


# ---------- Tauri / Rust desktop build (#86) ----------
# private signing key는 절대 commit 금지.
src-tauri/target/
src-tauri/gen/
*.msi
*.nsis
*.dmg
*.pkg

# ---------- Desktop sidecar binaries (#90) ----------
# backend PyInstaller 산출물. scripts/build_backend_sidecar.ps1 가 생성.
# 빌드 머신마다 산출 — git 에 올리지 않는다 (재현은 build script 로).
# 단, README.md 는 디렉토리 의도 + 안전 invariant 설명을 git 에 보존.
src-tauri/binaries/*
!src-tauri/binaries/README.md
backend/dist/
backend/build/
backend/autotrade-backend.spec
