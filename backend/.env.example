# Runtime
APP_ENV=local
APP_NAME=auto-trader-backend
DEFAULT_MODE=SIMULATION
ENABLE_LIVE_TRADING=false
ENABLE_AI_EXECUTION=false

# Server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Broker secrets - never put real values in git
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_PAPER=true

KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_ACCOUNT_NO=

# AI provider secrets - backend only
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database - SQLite by default for local dev; switch to PostgreSQL in prod
DATABASE_URL=sqlite:///./data/auto_trader.db
REDIS_URL=redis://localhost:6379/0

# Market data provider - "mock" (deterministic synthetic) or "yfinance" (Yahoo Finance)
MARKET_DATA_PROVIDER=mock
