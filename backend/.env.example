# Runtime
APP_ENV=local
APP_NAME=auto-trader-backend
DEFAULT_MODE=SIMULATION
ENABLE_LIVE_TRADING=false
ENABLE_AI_EXECUTION=false
ENABLE_FUTURES_LIVE_TRADING=false
# 작업 10 — 위험 기능 다중 잠금 (app.core.feature_flags). 기본 false 유지.
# crypto_futures_live 는 APP_ENV=local 에서 *영구* hard-block (단일 flag
# 만으로 절대 활성화 불가). kimp_strategy 는 전략 모듈 활성 여부일 뿐 실거래
# 허용 여부가 아니며, paper/mock 에서도 전략 테스트 가능.
ENABLE_CRYPTO_FUTURES_LIVE=false
ENABLE_KIMP_STRATEGY=false

# Server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Broker secrets - never put real values in git
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_PAPER=true
KIS_RATE_LIMIT_CALLS=5
KIS_RATE_LIMIT_WINDOW_SECONDS=1.0

KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_ACCOUNT_NO=

# AI provider secrets - backend only
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_RETRIES=2
ANTHROPIC_TIMEOUT_SECONDS=30.0

# Database - SQLite by default for local dev; switch to PostgreSQL in prod
DATABASE_URL=sqlite:///./data/auto_trader.db
REDIS_URL=redis://localhost:6379/0

# Market data provider - "mock" (deterministic synthetic) or "yfinance" (Yahoo Finance)
MARKET_DATA_PROVIDER=mock

# Background poller that updates OrderAuditLog with broker fill status
ENABLE_FILL_POLLING=false
FILL_POLLING_INTERVAL_SECONDS=5

# RiskPolicy thresholds — operator-tunable without code changes.
# Defaults match RiskPolicy() defaults; lower these to tighten risk in production.
RISK_MAX_ORDER_NOTIONAL=1000000
RISK_MAX_DAILY_LOSS=200000
RISK_MAX_POSITIONS=5
RISK_MAX_SYMBOL_EXPOSURE=1500000

# #64: Notifications (Telegram 1차 채널).
# 토큰은 backend/.env에만 — 절대 git/docs/frontend에 노출하지 말 것.
# 비워두면 NoOpChannel로 안전하게 동작 (알림 발송 0건).
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_MIN_SEVERITY=INFO
NOTIFICATIONS_DEDUPE_WINDOW_SECONDS=60
NOTIFICATIONS_ALWAYS_SEND_CRITICAL=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=5.0
TELEGRAM_MAX_RETRIES=1
